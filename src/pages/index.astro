---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Berces SpA | Instalación de Cámaras y Alarmas en Antofagasta">
  <!-- Fondo Base Oscuro y Malla de Degradados (Mesh Gradient) -->
  <div class="fixed inset-0 bg-[#040e1f] -z-50 overflow-hidden">
    <!-- Orbes de luz para dar el efecto Liquid Glass al hacer scroll -->
    <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-[#061d39] blur-[100px] opacity-80 animate-pulse" style="animation-duration: 12s;"></div>
    <div class="absolute top-[20%] right-[-10%] w-[40vw] h-[40vw] rounded-full bg-[#c29b40]/15 blur-[120px] opacity-60"></div>
    <div class="absolute bottom-[-20%] left-[20%] w-[60vw] h-[60vw] rounded-full bg-[#061d39] blur-[150px] opacity-90"></div>
  </div>

  <!-- Navbar Liquid Glass (iOS Style) -->
  <header class="fixed top-4 left-1/2 -translate-x-1/2 w-[calc(100%-2rem)] max-w-6xl z-50 rounded-2xl bg-white/5 backdrop-blur-2xl border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.4)]">
    <div class="px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <!-- Ícono del logo en Glass -->
        <div class="w-8 h-8 rounded-full bg-white/10 border border-white/20 flex items-center justify-center shadow-inner backdrop-blur-md">
          <svg class="w-4 h-4 text-[#c29b40]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <span class="font-semibold text-lg tracking-tight text-white/90">Berces SpA</span>
      </div>
      
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-white/60">
        <a href="#servicios" class="hover:text-white transition-colors">Servicios</a>
        <a href="#nosotros" class="hover:text-white transition-colors">Nuestra Misión</a>
      </nav>
      
      <div class="flex items-center">
        <!-- Botón Contacto Liquid Glass -->
        <a href="https://wa.me/56946198238" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-white px-5 py-2 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-xl border border-white/20 shadow-[inset_0_1px_1px_rgba(255,255,255,0.3),0_4px_10px_rgba(0,0,0,0.2)] transition-all flex items-center gap-2">
          <svg class="w-4 h-4 text-[#c29b40]" fill="currentColor" viewBox="0 0 24 24"><path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.964 9.964 0 001.333 4.993L2 22l5.233-1.237a9.994 9.994 0 004.779 1.217h.004c5.505 0 9.988-4.478 9.989-9.984 0-2.669-1.037-5.176-2.926-7.066C17.19 3.038 14.682 2 12.012 2zM12.012 20.264h-.003a8.318 8.318 0 01-4.246-1.155l-.304-.18-3.159.746.84-3.078-.198-.314a8.297 8.297 0 01-1.272-4.439c0-4.582 3.73-8.31 8.315-8.31 2.221 0 4.307.865 5.876 2.434s2.433 3.656 2.433 5.877c-.001 4.583-3.73 8.311-8.313 8.311zm4.56-6.236c-.25-.125-1.478-.73-1.706-.814-.23-.083-.396-.125-.563.125-.167.25-.645.814-.79.98-.146.166-.292.188-.542.063-.25-.125-1.054-.389-2.008-1.243-.743-.665-1.245-1.488-1.39-1.738-.147-.25-.016-.385.109-.51.112-.112.25-.292.375-.438.125-.146.166-.25.25-.417.083-.167.041-.313-.021-.438-.063-.125-.563-1.355-.771-1.854-.204-.485-.411-.42-.563-.427-.146-.006-.312-.006-.479-.006a.91.91 0 00-.666.313c-.23.25-.875.854-.875 2.084s.896 2.417 1.02 2.584c.125.166 1.761 2.688 4.264 3.769.596.257 1.061.411 1.423.526.598.191 1.143.164 1.57.1.48-.073 1.478-.604 1.687-1.188.208-.583.208-1.083.146-1.188-.062-.104-.229-.166-.479-.292z"/></svg>
          Contacto
        </a>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero Section: Claro, con Glassmorphism y la imagen bien integrada -->
    <section class="relative pt-40 pb-20 md:pt-48 md:pb-24 min-h-[95vh] flex items-center">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center w-full">
        
        <!-- Textos -->
        <div class="relative z-10 text-left">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-sm text-[#c29b40] font-medium mb-8 backdrop-blur-md shadow-sm">
            <div class="w-1.5 h-1.5 rounded-full bg-[#c29b40] animate-pulse"></div>
            Instaladores operativos en Antofagasta
          </div>
          
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-white mb-6 leading-[1.1]">
            Protege lo que importa con <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#c29b40] to-[#e4c271]">Seguridad Inteligente.</span>
          </h1>
          
          <p class="text-lg md:text-xl text-white/70 mb-10 leading-relaxed font-light max-w-xl">
            Soluciones de seguridad electrónica para empresas, comercios y comunidades. Proveemos tecnología de vanguardia, instalación profesional y mantención constante.
          </p>
          
          <div class="flex flex-col sm:flex-row items-center gap-4">
            <!-- Botón CTA Liquid / Elegante -->
            <a href="https://wa.me/56946198238" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-8 py-4 rounded-full bg-gradient-to-b from-[#c29b40] to-[#a38030] text-white font-medium hover:scale-[1.02] transition-all flex items-center justify-center gap-2 shadow-[inset_0_1px_1px_rgba(255,255,255,0.4),0_8px_20px_rgba(194,155,64,0.3)]">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
              Cotizar Proyecto
            </a>
            
            <a href="#servicios" class="w-full sm:w-auto px-8 py-4 rounded-full bg-white/5 hover:bg-white/10 backdrop-blur-xl border border-white/10 text-white font-medium shadow-lg transition-all flex items-center justify-center">
              Ver Servicios
            </a>
          </div>

          <!-- Resumen de servicios rápido en Glass -->
          <div class="mt-12 flex flex-wrap gap-4">
             <div class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 backdrop-blur-md flex items-center gap-2 text-sm text-white/70">
                <svg class="w-4 h-4 text-[#c29b40]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Instalación
             </div>
             <div class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 backdrop-blur-md flex items-center gap-2 text-sm text-white/70">
                <svg class="w-4 h-4 text-[#c29b40]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Venta
             </div>
             <div class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 backdrop-blur-md flex items-center gap-2 text-sm text-white/70">
                <svg class="w-4 h-4 text-[#c29b40]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Mantención
             </div>
          </div>
        </div>

        <!-- Imagen / Graphic -->
        <div class="relative w-full h-[500px] lg:h-[600px] rounded-3xl overflow-hidden border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
          <img 
            src="https://images.unsplash.com/photo-1558002038-1055907df827?q=80&w=1000&auto=format&fit=crop" 
            alt="Panel de seguridad electrónica" 
            class="w-full h-full object-cover opacity-80"
          />
          <!-- Gradiente interior para fundir la imagen con el diseño -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#040e1f] via-[#040e1f]/20 to-transparent"></div>
          
          <!-- Elemento Glass superpuesto en la imagen -->
          <div class="absolute bottom-8 left-8 right-8 bg-white/10 backdrop-blur-xl border border-white/20 p-5 rounded-2xl flex items-center gap-4 shadow-xl">
            <div class="w-12 h-12 rounded-full bg-[#c29b40]/20 flex items-center justify-center border border-[#c29b40]/30 shrink-0">
               <svg class="w-6 h-6 text-[#c29b40]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            </div>
            <div>
               <p class="text-white font-medium">Monitoreo 24/7</p>
               <p class="text-white/60 text-sm font-light">Vigilancia continua desde cualquier dispositivo móvil.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Services Section: 100% Liquid Glass Cards -->
    <section id="servicios" class="py-24 relative z-10">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-semibold text-white mb-4 tracking-tight">El ecosistema de seguridad</h2>
          <p class="text-white/60 text-lg max-w-2xl mx-auto font-light">Ofrecemos instalación y configuración llave en mano. Tú nos dices qué necesitas proteger, nosotros hacemos el resto.</p>
        </div>
        
        <div class="grid md:grid-cols-3 gap-6">
          
          <!-- Card 1: Cámaras (Glassmorphism Puro) -->
          <div class="bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition-colors shadow-[0_8px_30px_rgba(0,0,0,0.2)] flex flex-col group">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-white/10 to-white/5 border border-white/20 flex items-center justify-center mb-6 shadow-inner text-[#c29b40] group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </div>
            
            <h3 class="text-xl font-semibold text-white mb-3">Cámaras de Vigilancia</h3>
            <p class="text-white/60 text-sm leading-relaxed mb-8 font-light flex-1">
              Sistemas de CCTV y cámaras IP Wi-Fi. Te entregamos la aplicación configurada en tu teléfono para monitoreo en vivo y revisión de grabaciones.
            </p>
            
            <div class="bg-black/20 rounded-xl p-4 border border-white/5">
               <ul class="space-y-3">
                 <li class="flex items-center gap-3 text-sm text-white/80"><div class="w-1.5 h-1.5 rounded-full bg-[#c29b40]"></div> Venta de equipos HD/4K</li>
                 <li class="flex items-center gap-3 text-sm text-white/80"><div class="w-1.5 h-1.5 rounded-full bg-[#c29b40]"></div> Instalación estética y limpia</li>
               </ul>
            </div>
          </div>
          
          <!-- Card 2: Alarmas -->
          <div class="bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition-colors shadow-[0_8px_30px_rgba(0,0,0,0.2)] flex flex-col group">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-white/10 to-white/5 border border-white/20 flex items-center justify-center mb-6 shadow-inner text-[#c29b40] group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </div>
            
            <h3 class="text-xl font-semibold text-white mb-3">Sistemas de Alarmas</h3>
            <p class="text-white/60 text-sm leading-relaxed mb-8 font-light flex-1">
              Detección de intrusos. Instalamos sensores de movimiento, contactos magnéticos para puertas/ventanas y sirenas disuasivas de alta potencia.
            </p>
            
            <div class="bg-black/20 rounded-xl p-4 border border-white/5">
               <ul class="space-y-3">
                 <li class="flex items-center gap-3 text-sm text-white/80"><div class="w-1.5 h-1.5 rounded-full bg-[#c29b40]"></div> Alertas directas al celular</li>
                 <li class="flex items-center gap-3 text-sm text-white/80"><div class="w-1.5 h-1.5 rounded-full bg-[#c29b40]"></div> Configuración personalizada</li>
               </ul>
            </div>
          </div>
          
          <!-- Card 3: Acceso -->
          <div class="bg-white/5 backdrop-blur-2xl border border-white/10 rounded-3xl p-8 hover:bg-white/10 transition-colors shadow-[0_8px_30px_rgba(0,0,0,0.2)] flex flex-col group">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-white/10 to-white/5 border border-white/20 flex items-center justify-center mb-6 shadow-inner text-[#c29b40] group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4" />
              </svg>
            </div>
            
            <h3 class="text-xl font-semibold text-white mb-3">Control de Accesos</h3>
            <p class="text-white/60 text-sm leading-relaxed mb-8 font-light flex-1">
              Restringe y registra quién entra a tus instalaciones. Ideal para oficinas, recintos corporativos y edificios residenciales.
            </p>
            
            <div class="bg-black/20 rounded-xl p-4 border border-white/5">
               <ul class="space-y-3">
                 <li class="flex items-center gap-3 text-sm text-white/80"><div class="w-1.5 h-1.5 rounded-full bg-[#c29b40]"></div> Biometría y tarjetas</li>
                 <li class="flex items-center gap-3 text-sm text-white/80"><div class="w-1.5 h-1.5 rounded-full bg-[#c29b40]"></div> Cerraduras electromagnéticas</li>
               </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Mission & About Section con Imagen de Arquitectura/Seguridad -->
    <section id="nosotros" class="py-24 relative z-10">
      <div class="max-w-7xl mx-auto px-6">
        <div class="bg-white/5 backdrop-blur-3xl border border-white/10 rounded-[2rem] p-8 md:p-12 relative overflow-hidden shadow-2xl">
          
          <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
             <div>
                <span class="text-[#c29b40] font-medium text-sm tracking-widest uppercase mb-4 block">Nuestra Misión</span>
                <h2 class="text-3xl md:text-4xl font-semibold text-white mb-6 tracking-tight">Tu seguridad, nuestro compromiso.</h2>
                <div class="space-y-6 text-white/70 font-light leading-relaxed">
                  <p>
                    Proteger personas, hogares y empresas mediante soluciones de seguridad electrónica eficientes y confiables. Entregamos tecnología de vanguardia, un servicio profesional y atención oportuna.
                  </p>
                </div>
                
                <div class="mt-8 flex items-center gap-4 bg-black/20 border border-white/5 rounded-2xl p-4 w-fit">
                   <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center border border-white/10 shrink-0">
                      <svg class="w-5 h-5 text-[#c29b40]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                   </div>
                   <div>
                     <span class="text-white text-sm font-medium block">Servicio en todo Antofagasta</span>
                     <span class="text-white/50 text-xs">Sector Norte, Centro y Sur</span>
                   </div>
                </div>
             </div>
             
             <!-- Imagen Descriptiva en Contenedor Glass -->
             <div class="relative h-64 md:h-full min-h-[300px] border border-white/10 rounded-3xl overflow-hidden shadow-2xl">
                <img src="https://images.unsplash.com/photo-1557597774-9d273605dfa9?q=80&w=800&auto=format&fit=crop" alt="Cámara de vigilancia empresarial" class="absolute inset-0 w-full h-full object-cover" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#040e1f] via-transparent to-transparent opacity-80"></div>
                <div class="absolute bottom-6 left-6 right-6">
                   <p class="text-white font-medium text-lg">Berces SpA</p>
                   <p class="text-white/60 text-sm">Expertos en seguridad electrónica</p>
                </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Final Glassmorphism Puro -->
    <section class="py-24 relative z-10">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-4xl md:text-5xl font-semibold text-white mb-6 tracking-tight">Agenda una evaluación técnica.</h2>
        <p class="text-lg text-white/60 mb-10 font-light">Contáctanos por WhatsApp para cotizar equipos o solicitar una visita a tus instalaciones. Respuesta inmediata.</p>
        
        <a href="https://wa.me/56946198238" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-xl border border-white/20 text-white font-medium shadow-[0_8px_32px_rgba(0,0,0,0.3)] transition-all hover:scale-105 group">
          <svg class="w-6 h-6 text-[#c29b40] group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.964 9.964 0 001.333 4.993L2 22l5.233-1.237a9.994 9.994 0 004.779 1.217h.004c5.505 0 9.988-4.478 9.989-9.984 0-2.669-1.037-5.176-2.926-7.066C17.19 3.038 14.682 2 12.012 2zM12.012 20.264h-.003a8.318 8.318 0 01-4.246-1.155l-.304-.18-3.159.746.84-3.078-.198-.314a8.297 8.297 0 01-1.272-4.439c0-4.582 3.73-8.31 8.315-8.31 2.221 0 4.307.865 5.876 2.434s2.433 3.656 2.433 5.877c-.001 4.583-3.73 8.311-8.313 8.311zm4.56-6.236c-.25-.125-1.478-.73-1.706-.814-.23-.083-.396-.125-.563.125-.167.25-.645.814-.79.98-.146.166-.292.188-.542.063-.25-.125-1.054-.389-2.008-1.243-.743-.665-1.245-1.488-1.39-1.738-.147-.25-.016-.385.109-.51.112-.112.25-.292.375-.438.125-.146.166-.25.25-.417.083-.167.041-.313-.021-.438-.063-.125-.563-1.355-.771-1.854-.204-.485-.411-.42-.563-.427-.146-.006-.312-.006-.479-.006a.91.91 0 00-.666.313c-.23.25-.875.854-.875 2.084s.896 2.417 1.02 2.584c.125.166 1.761 2.688 4.264 3.769.596.257 1.061.411 1.423.526.598.191 1.143.164 1.57.1.48-.073 1.478-.604 1.687-1.188.208-.583.208-1.083.146-1.188-.062-.104-.229-.166-.479-.292z"/></svg>
          Hablar por WhatsApp
        </a>
      </div>
    </section>
  </main>

  <!-- Footer Clean Glass -->
  <footer class="border-t border-white/10 bg-[#040e1f]/80 backdrop-blur-xl py-12 relative z-10">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-[#c29b40]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <span class="font-medium text-white/90">Berces SpA</span>
      </div>
      
