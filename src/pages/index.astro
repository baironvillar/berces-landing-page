---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Berces SpA | Instalación de Cámaras y Alarmas en Antofagasta">
  <!-- Ethereal Glass Background -->
  <div class="fixed inset-0 z-[-1] overflow-hidden bg-[#0A1118]">
    <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-[#F7C731]/5 blur-[120px] mix-blend-screen"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[60vw] h-[60vw] rounded-full bg-[#FDD835]/5 blur-[150px] mix-blend-screen"></div>
  </div>

  <!-- Floating Glass Nav -->
  <header class="fixed top-6 left-1/2 -translate-x-1/2 w-max max-w-[calc(100%-2rem)] z-40 rounded-full bg-black/40 backdrop-blur-2xl ring-1 ring-white/10 p-1.5 flex items-center shadow-2xl transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
    <div class="flex items-center gap-8 pl-4 pr-1">
      <div class="flex items-center gap-3">
        <!-- Code-based Logo -->
        <div class="relative flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-br from-[#F7C731]/20 to-[#1A232E]/50 border border-[#F7C731]/30 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1)]">
          <svg class="w-4 h-4 text-[#F7C731]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            <circle cx="12" cy="11" r="2.5" stroke-width="2.5" />
          </svg>
        </div>
        <div class="hidden sm:flex items-center gap-2 border-l border-white/10 pl-3">
          <div class="w-1.5 h-1.5 rounded-full bg-[#F7C731] shadow-[0_0_10px_rgba(247,199,49,0.8)] animate-pulse"></div>
          <span class="font-clash font-bold text-sm tracking-wider text-white">BERCES SpA</span>
        </div>
      </div>
      
      <nav class="hidden md:flex items-center gap-6 text-[13px] font-medium text-white/50">
        <a href="#servicios" class="hover:text-white transition-colors">Servicios</a>
        <a href="#nosotros" class="hover:text-white transition-colors">Misión</a>
      </nav>
      
      <!-- CTA Nav -->
      <a href="https://wa.me/56946198238" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between bg-white text-black px-5 py-2.5 rounded-full text-xs font-bold hover:bg-[#FDD835] hover:text-[#0A1118] transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] active:scale-[0.98]">
        <span class="mr-3">WhatsApp Rápido</span>
        <div class="w-6 h-6 rounded-full bg-black/10 flex items-center justify-center transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-0.5 group-hover:-translate-y-[1px] group-hover:scale-105">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </div>
      </a>
    </div>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[100dvh] flex items-center justify-center pt-32 pb-24 px-4 overflow-hidden">
      <div class="max-w-5xl mx-auto w-full flex flex-col items-center text-center">
        <!-- Eyebrow -->
        <div class="rounded-full px-4 py-1.5 text-[11px] uppercase tracking-[0.2em] font-medium text-[#F7C731] ring-1 ring-[#F7C731]/30 mb-8 backdrop-blur-md bg-[#F7C731]/[0.05]">
          Especialistas de Servicios en Antofagasta
        </div>
        
        <!-- Headline -->
        <h1 class="text-5xl md:text-7xl lg:text-[5.5rem] font-clash font-semibold tracking-tight text-white mb-8 leading-[1.05] drop-shadow-2xl">
          Protege tu patrimonio <br class="hidden md:block"/>
          <span class="text-white/40">antes de que sea tarde.</span>
        </h1>
        
        <p class="text-lg md:text-xl text-white/60 mb-14 font-light max-w-3xl mx-auto leading-relaxed">
          En <strong class="text-white font-medium">Berces SpA</strong> diseñamos e instalamos sistemas de vigilancia, alarmas anti-intrusión y control de acceso. Vigila tu negocio u hogar en tiempo real desde tu celular.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto">
          <!-- Nested Button Architecture -->
          <a href="https://wa.me/56946198238" target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center justify-center bg-[#F7C731] text-[#0A1118] px-8 py-4 rounded-full text-base font-bold shadow-[0_0_40px_rgba(247,199,49,0.3)] transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:bg-[#FDD835] active:scale-[0.98] w-full sm:w-auto overflow-hidden">
            <span class="relative z-10 pr-10">Cotizar servicio por WhatsApp</span>
            <div class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/20 flex items-center justify-center transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:bg-black/30 group-hover:translate-x-[2px] group-hover:scale-105">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>
          <span class="text-xs text-white/40 mt-3 sm:mt-0 sm:ml-4 font-medium tracking-wide">Respuesta en menos de 30 min.</span>
        </div>
      </div>
    </section>

    <!-- Services Asymmetrical Bento Grid -->
    <section id="servicios" class="py-32 px-4 relative z-10">
      <div class="max-w-7xl mx-auto">
        
        <div class="mb-20">
          <div class="rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-white/50 ring-1 ring-white/10 mb-6 backdrop-blur-md bg-white/[0.02] w-max">
            Servicios Integrales
          </div>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-clash font-medium tracking-tight text-white mb-6">
            Infraestructura de control.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
          
          <!-- Bento Card 1: CCTV (Large) -->
          <div class="md:col-span-8 flex flex-col relative group rounded-[2rem] bg-white/[0.02] ring-1 ring-white/10 p-2 overflow-hidden hover:bg-white/[0.03] transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
            <div class="absolute inset-0 bg-gradient-to-br from-[#F7C731]/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] z-0"></div>
            <div class="relative z-10 bg-[#1A232E] rounded-[calc(2rem-0.5rem)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] h-full min-h-[400px] p-8 md:p-12 flex flex-col justify-between overflow-hidden">
              <div class="flex items-start justify-between mb-20 relative z-20">
                <div class="w-12 h-12 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-[#F7C731]">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                </div>
                <span class="text-xs font-mono text-white/30 uppercase tracking-wider">CCTV-01</span>
              </div>
              
              <div class="relative z-20">
                <h3 class="text-2xl md:text-3xl font-clash text-white mb-4">Cámaras de Vigilancia IP/HD</h3>
                <p class="text-white/50 font-light leading-relaxed max-w-md">
                  Vigila tu propiedad 24/7 en alta definición. Servicios de cámaras disuasivas con visualización en tiempo real desde tu smartphone, estés donde estés.
                </p>
              </div>

              <!-- Decorative Abstract Graphic -->
              <div class="absolute inset-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1557597774-9d273605dfa9?q=80&w=1200&auto=format&fit=crop')] bg-cover bg-center opacity-[0.15] mix-blend-luminosity mask-image-linear-gradient-to-t-transparent pointer-events-none transition-transform duration-1000 group-hover:scale-105"></div>
            </div>
          </div>

          <!-- Bento Card 2: Alarmas (Stacked Small) -->
          <div class="md:col-span-4 flex flex-col relative group rounded-[2rem] bg-white/[0.02] ring-1 ring-white/10 p-2 overflow-hidden hover:bg-white/[0.03] transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
            <div class="relative z-10 bg-[#1A232E] rounded-[calc(2rem-0.5rem)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] h-full p-8 flex flex-col justify-between min-h-[300px] md:min-h-0 overflow-hidden">
              <div class="w-12 h-12 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-[#FDD835] mb-12 relative z-20">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
              </div>
              
              <div class="relative z-20">
                <h3 class="text-xl font-clash text-white mb-3">Sistemas de Intrusión</h3>
                <p class="text-white/50 text-sm font-light leading-relaxed">
                  Evita robos antes de que ocurran. Sensores perimetrales y sirenas conectadas directamente a tu teléfono.
                </p>
              </div>

              <!-- Decorative Abstract Graphic -->
              <div class="absolute inset-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-screen mask-image-linear-gradient-to-t-transparent pointer-events-none transition-transform duration-1000 group-hover:scale-105"></div>
            </div>
          </div>

          <!-- Bento Card 3: Control Acceso (col-span-4) -->
          <div class="md:col-span-4 flex flex-col relative group rounded-[2rem] bg-white/[0.02] ring-1 ring-white/10 p-2 overflow-hidden hover:bg-white/[0.03] transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
            <div class="relative z-10 bg-[#1A232E] rounded-[calc(2rem-0.5rem)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] h-full p-8 flex flex-col justify-between min-h-[300px] md:min-h-0 overflow-hidden">
              <div class="w-12 h-12 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-[#F7C731] mb-12 relative z-20">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4" /></svg>
              </div>
              
              <div class="relative z-20">
                <h3 class="text-xl font-clash text-white mb-3">Control de Accesos</h3>
                <p class="text-white/50 text-sm font-light leading-relaxed">
                  Decide quién entra. Biometría, chapas magnéticas y tarjetas para recintos y oficinas en Antofagasta.
                </p>
              </div>

              <div class="absolute inset-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1555664424-778a1e5e1b48?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-luminosity mask-image-linear-gradient-to-t-transparent pointer-events-none transition-transform duration-1000 group-hover:scale-105"></div>
            </div>
          </div>

          <!-- Bento Card 4: Mantención (col-span-4) -->
          <div class="md:col-span-4 flex flex-col relative group rounded-[2rem] bg-white/[0.02] ring-1 ring-white/10 p-2 overflow-hidden hover:bg-white/[0.03] transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
            <div class="relative z-10 bg-[#1A232E] rounded-[calc(2rem-0.5rem)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] h-full p-8 flex flex-col justify-between min-h-[300px] overflow-hidden">
              <div class="w-12 h-12 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-[#FDD835] mb-12 relative z-20">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              
              <div class="relative z-20">
                <h3 class="text-xl font-clash text-white mb-3">Mantención Continua</h3>
                <p class="text-white/50 text-sm font-light leading-relaxed">
                  Asistencia técnica rápida en Antofagasta. Aseguramos que tus equipos nunca dejen de grabar.
                </p>
              </div>

              <div class="absolute inset-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=1200&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-luminosity mask-image-linear-gradient-to-t-transparent pointer-events-none transition-transform duration-1000 group-hover:scale-105"></div>
            </div>
          </div>

          <!-- Bento Card 5: Reparaciones (col-span-4) -->
          <div class="md:col-span-4 flex flex-col relative group rounded-[2rem] bg-white/[0.02] ring-1 ring-white/10 p-2 overflow-hidden hover:bg-white/[0.03] transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
            <div class="absolute inset-0 bg-gradient-to-br from-[#FDD835]/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] z-0"></div>
            <div class="relative z-10 bg-[#1A232E] rounded-[calc(2rem-0.5rem)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] h-full p-8 flex flex-col justify-between min-h-[300px] overflow-hidden">
              <div class="w-12 h-12 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-[#F7C731] mb-12 relative z-20">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
              </div>
              
              <div class="relative z-20">
                <h3 class="text-xl font-clash text-white mb-3">Reparaciones de Infraestructura</h3>
                <p class="text-white/50 text-sm font-light leading-relaxed">
                  Soluciones constructivas complementarias: reparación de paredes, techumbres y estructuras de material ligero.
                </p>
              </div>
              
              <div class="absolute inset-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center opacity-[0.08] mix-blend-luminosity mask-image-linear-gradient-to-t-transparent pointer-events-none transition-transform duration-1000 group-hover:scale-105"></div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-40 px-4 relative z-10 flex flex-col items-center justify-center text-center">
      <div class="rounded-full px-4 py-1 text-[11px] uppercase tracking-[0.2em] font-medium text-[#F7C731] ring-1 ring-[#F7C731]/30 mb-8 backdrop-blur-md bg-[#F7C731]/[0.05]">
        Berces SpA - Tu aliado estratégico
      </div>
      
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-clash font-semibold tracking-tight text-white mb-6 max-w-3xl">
        ¿Listo para proteger tu espacio?
      </h2>
      
      <p class="text-lg text-white/50 font-light mb-12 max-w-xl">
        Evita riesgos innecesarios. Nuestro equipo técnico en Antofagasta está preparado para evaluar tu recinto y brindarte una solución a medida.
      </p>
      
      <a href="https://wa.me/56946198238" target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center justify-center bg-[#F7C731] text-[#0A1118] px-8 py-4 rounded-full text-base font-bold shadow-[0_0_40px_rgba(247,199,49,0.3)] transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:bg-[#FDD835] active:scale-[0.98] overflow-hidden">
        <span class="relative z-10 pr-12">Enviar mensaje al Técnico</span>
        <div class="absolute right-2 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-black/20 flex items-center justify-center transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:bg-black/30 group-hover:translate-x-[2px] group-hover:scale-105">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </div>
      </a>
    </section>

  </main>

  <footer class="border-t border-white/[0.05] py-12 px-6 relative z-10 bg-[#0A1118]">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex flex-col md:flex-row items-center gap-4 text-xs font-mono text-white/30 uppercase tracking-widest">
        <!-- Logo Footer Code-based -->
        <div class="flex items-center justify-center w-6 h-6 rounded-md bg-[#F7C731]/10 border border-[#F7C731]/20 opacity-60 hover:opacity-100 transition-opacity">
          <svg class="w-3 h-3 text-[#F7C731]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            <circle cx="12" cy="11" r="2.5" stroke-width="2.5" />
          </svg>
        </div>
        <span class="hidden md:block w-1 h-1 rounded-full bg-white/10"></span>
        <span>© {new Date().getFullYear()} BERCES SpA</span>
        <span class="hidden md:block w-1 h-1 rounded-full bg-white/10"></span>
        <span>Antofagasta, Chile</span>
      </div>
      
      <div class="text-xs font-mono text-white/30 uppercase tracking-widest">
        Arquitectura por <a href="https://www.linkedin.com/in/baironvillarberrios" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors">Bairon Villar</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .mask-image-linear-gradient-to-t-transparent {
    -webkit-mask-image: linear-gradient(to top, black, transparent);
    mask-image: linear-gradient(to top, black, transparent);
  }
</style>
