---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Berces SpA | Instalación de Cámaras y Alarmas en Antofagasta">
  <!-- Ethereal Glass Background -->
  <div class="fixed inset-0 z-[-1] overflow-hidden bg-[#050505]">
    <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-emerald-900/10 blur-[120px] mix-blend-screen"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[60vw] h-[60vw] rounded-full bg-indigo-900/10 blur-[150px] mix-blend-screen"></div>
  </div>

  <!-- Floating Glass Nav -->
  <header class="fixed top-6 left-1/2 -translate-x-1/2 w-max max-w-[calc(100%-2rem)] z-40 rounded-full bg-black/40 backdrop-blur-2xl ring-1 ring-white/10 p-1.5 flex items-center shadow-2xl transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
    <div class="flex items-center gap-8 pl-4 pr-1">
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.8)]"></div>
        <span class="font-clash font-semibold text-sm tracking-wide text-white/90">BERCES</span>
      </div>
      
      <nav class="hidden md:flex items-center gap-6 text-[13px] font-medium text-white/50">
        <a href="#servicios" class="hover:text-white transition-colors">Servicios</a>
        <a href="#servicios" class="hover:text-white transition-colors">Misión</a>
      </nav>
      
      <!-- CTA Nav -->
      <a href="https://wa.me/56946198238" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-between bg-white text-black px-4 py-2.5 rounded-full text-xs font-semibold hover:bg-white/90 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] active:scale-[0.98]">
        <span class="mr-3">Cotizar</span>
        <div class="w-6 h-6 rounded-full bg-black/10 flex items-center justify-center transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-0.5 group-hover:-translate-y-[1px] group-hover:scale-105">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </div>
      </a>
    </div>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[100dvh] flex items-center justify-center pt-32 pb-24 px-4 overflow-hidden">
      <div class="max-w-5xl mx-auto w-full flex flex-col items-center text-center">
        <!-- Eyebrow -->
        <div class="rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-white/50 ring-1 ring-white/10 mb-8 backdrop-blur-md bg-white/[0.02]">
          Antofagasta, Chile
        </div>
        
        <!-- Headline -->
        <h1 class="text-5xl md:text-7xl lg:text-[5.5rem] font-clash font-medium tracking-tight text-white mb-8 leading-[1.05] drop-shadow-2xl">
          Seguridad electrónica <br class="hidden md:block"/>
          <span class="text-white/40">sin compromisos.</span>
        </h1>
        
        <p class="text-lg md:text-xl text-white/50 mb-14 font-light max-w-2xl mx-auto leading-relaxed">
          Diseñamos, instalamos y mantenemos ecosistemas de vigilancia inteligente y control de acceso. Arquitectura de protección de nivel corporativo para tu tranquilidad.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto">
          <!-- Nested Button Architecture -->
          <a href="https://wa.me/56946198238" target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center justify-center bg-white text-black px-6 py-4 rounded-full text-sm font-semibold transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:bg-gray-100 active:scale-[0.98] w-full sm:w-auto overflow-hidden">
            <span class="relative z-10 pr-10">Agenda una evaluación</span>
            <div class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/5 flex items-center justify-center transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:bg-black/10 group-hover:translate-x-[2px] group-hover:scale-105">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Services Asymmetrical Bento Grid -->
    <section id="servicios" class="py-32 px-4 relative z-10">
      <div class="max-w-7xl mx-auto">
        
        <div class="mb-20">
          <div class="rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-white/50 ring-1 ring-white/10 mb-6 backdrop-blur-md bg-white/[0.02] w-max">
            El Ecosistema
          </div>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-clash font-medium tracking-tight text-white mb-6">
            Infraestructura de control.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
          
          <!-- Bento Card 1: CCTV (Large) -->
          <div class="md:col-span-8 flex flex-col relative group rounded-[2rem] bg-white/[0.02] ring-1 ring-white/10 p-2 overflow-hidden hover:bg-white/[0.03] transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
            <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] z-0"></div>
            <div class="relative z-10 bg-[#0a0a0a] rounded-[calc(2rem-0.5rem)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] h-full min-h-[400px] p-8 md:p-12 flex flex-col justify-between overflow-hidden">
              <div class="flex items-start justify-between mb-20 relative z-20">
                <div class="w-12 h-12 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-emerald-400">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                </div>
                <span class="text-xs font-mono text-white/30 uppercase tracking-wider">CCTV-01</span>
              </div>
              
              <div class="relative z-20">
                <h3 class="text-2xl md:text-3xl font-clash text-white mb-4">Cámaras de Vigilancia IP/HD</h3>
                <p class="text-white/50 font-light leading-relaxed max-w-md">
                  Monitoreo 24/7 en alta definición. Arquitectura de red segura, visualización en tiempo real desde tu dispositivo móvil y almacenamiento continuo.
                </p>
              </div>

              <!-- Decorative Abstract Graphic -->
              <div class="absolute inset-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1557597774-9d273605dfa9?q=80&w=1200&auto=format&fit=crop')] bg-cover bg-center opacity-[0.15] mix-blend-luminosity mask-image-linear-gradient-to-t-transparent pointer-events-none transition-transform duration-1000 group-hover:scale-105"></div>
            </div>
          </div>

          <!-- Bento Card 2: Alarmas (Stacked Small) -->
          <div class="md:col-span-4 flex flex-col relative group rounded-[2rem] bg-white/[0.02] ring-1 ring-white/10 p-2 overflow-hidden hover:bg-white/[0.03] transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
            <div class="relative z-10 bg-[#0a0a0a] rounded-[calc(2rem-0.5rem)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] h-full p-8 flex flex-col justify-between min-h-[300px] md:min-h-0 overflow-hidden">
              <div class="w-12 h-12 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-rose-400 mb-12 relative z-20">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
              </div>
              
              <div class="relative z-20">
                <h3 class="text-xl font-clash text-white mb-3">Sistemas de Intrusión</h3>
                <p class="text-white/50 text-sm font-light leading-relaxed">
                  Sensores de movimiento y contactos magnéticos enlazados a sirenas disuasivas. Notificaciones instantáneas.
                </p>
              </div>

              <!-- Decorative Abstract Graphic -->
              <div class="absolute inset-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-screen mask-image-linear-gradient-to-t-transparent pointer-events-none transition-transform duration-1000 group-hover:scale-105"></div>
            </div>
          </div>

          <!-- Bento Card 3: Control Acceso (Stacked Small) -->
          <div class="md:col-span-5 flex flex-col relative group rounded-[2rem] bg-white/[0.02] ring-1 ring-white/10 p-2 overflow-hidden hover:bg-white/[0.03] transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
            <div class="relative z-10 bg-[#0a0a0a] rounded-[calc(2rem-0.5rem)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] h-full p-8 flex flex-col justify-between min-h-[300px] md:min-h-0 overflow-hidden">
              <div class="w-12 h-12 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-blue-400 mb-12 relative z-20">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4" /></svg>
              </div>
              
              <div class="relative z-20">
                <h3 class="text-xl font-clash text-white mb-3">Control de Accesos</h3>
                <p class="text-white/50 text-sm font-light leading-relaxed">
                  Biometría, credenciales y cerraduras electromagnéticas para restringir y auditar flujos de personas.
                </p>
              </div>

              <!-- Decorative Abstract Graphic -->
              <div class="absolute inset-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1555664424-778a1e5e1b48?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-luminosity mask-image-linear-gradient-to-t-transparent pointer-events-none transition-transform duration-1000 group-hover:scale-105"></div>
            </div>
          </div>

          <!-- Bento Card 4: Soporte Técnico (Wide) -->
          <div class="md:col-span-7 flex flex-col relative group rounded-[2rem] bg-white/[0.02] ring-1 ring-white/10 p-2 overflow-hidden hover:bg-white/[0.03] transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
            <div class="relative z-10 bg-[#0a0a0a] rounded-[calc(2rem-0.5rem)] shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)] h-full p-8 md:p-12 flex flex-col justify-between min-h-[300px] overflow-hidden">
              <div class="w-12 h-12 rounded-full bg-white/5 ring-1 ring-white/10 flex items-center justify-center text-amber-400 mb-12 relative z-20">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              
              <div class="relative z-20">
                <h3 class="text-2xl font-clash text-white mb-3">Mantención Continua</h3>
                <p class="text-white/50 font-light leading-relaxed max-w-sm">
                  Nuestro servicio no termina en la instalación. Aseguramos que tus equipos operen al máximo rendimiento año tras año.
                </p>
              </div>

              <!-- Decorative Abstract Graphic -->
              <div class="absolute inset-0 w-full h-full bg-[url('https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=1200&auto=format&fit=crop')] bg-cover bg-center opacity-10 mix-blend-luminosity mask-image-linear-gradient-to-t-transparent pointer-events-none transition-transform duration-1000 group-hover:scale-105"></div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-40 px-4 relative z-10 flex flex-col items-center justify-center text-center">
      <div class="rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-white/50 ring-1 ring-white/10 mb-8 backdrop-blur-md bg-white/[0.02]">
        Hablemos de tu proyecto
      </div>
      
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-clash font-medium tracking-tight text-white mb-10 max-w-3xl">
        Seguridad sin fricción. <br class="hidden md:block"/>
        Desempeño absoluto.
      </h2>
      
      <a href="https://wa.me/56946198238" target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center justify-center bg-white text-black px-8 py-4 rounded-full text-base font-semibold transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:bg-gray-100 active:scale-[0.98] overflow-hidden">
        <span class="relative z-10 pr-12">Contactar Ingeniería</span>
        <div class="absolute right-2 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-black/5 flex items-center justify-center transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:bg-black/10 group-hover:translate-x-[2px] group-hover:scale-105">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </div>
      </a>
    </section>

  </main>

  <footer class="border-t border-white/[0.05] py-12 px-6 relative z-10 bg-[#050505]">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex flex-col md:flex-row items-center gap-4 text-xs font-mono text-white/30 uppercase tracking-widest">
        <span>© {new Date().getFullYear()} BERCES SpA</span>
        <span class="hidden md:block w-1 h-1 rounded-full bg-white/10"></span>
        <span>Antofagasta, Chile</span>
      </div>
      
      <div class="text-xs font-mono text-white/30 uppercase tracking-widest">
        Arquitectura por <a href="https://www.linkedin.com/in/baironvillarberrios" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors">Bairon Villar</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .mask-image-linear-gradient-to-t-transparent {
    -webkit-mask-image: linear-gradient(to top, black, transparent);
    mask-image: linear-gradient(to top, black, transparent);
  }
</style>
